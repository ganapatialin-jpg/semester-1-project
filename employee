// CREATE Operation 
void addEmployee() {
    FILE *fp = fopen("employee.txt", "a"); // Append mode [cite: 12]
    Employee e;

    printf("Enter Employee ID: ");
    scanf("%d", &e.id);
    printf("Enter Name: ");
    scanf(" %[^\n]", e.name);
    printf("Enter Designation: ");
    scanf(" %[^\n]", e.designation);
    printf("Enter Salary: ");
    scanf("%f", &e.salary);

    fprintf(fp, "%d %s %s %.2f\n", e.id, e.name, e.designation, e.salary);
    fclose(fp);
    printf("Record saved successfully.\n");
}

// READ Operation 
void displayEmployees() {
    FILE *fp = fopen("employee.txt", "r");
    Employee e;
    
    if (fp == NULL) {
        printf("No records found.\n");
        return;
    }

    printf("\nID\tName\t\tDesignation\tSalary\n");
    printf("----------------------------------------------\n");
    // fscanf return-value checking 
    while (fscanf(fp, "%d %s %s %f", &e.id, e.name, e.designation, &e.salary) == 4) {
        printf("%d\t%s\t\t%s\t%.2f\n", e.id, e.name, e.designation, e.salary);
    }
    fclose(fp);
}

// SEARCH Operation [cite: 20]
void searchEmployee() {
    FILE *fp = fopen("employee.txt", "r");
    Employee e;
    int targetID, found = 0; // Usage of flags for feedback [cite: 35]

    printf("Enter ID to search: ");
    scanf("%d", &targetID);

    while (fscanf(fp, "%d %s %s %f", &e.id, e.name, e.designation, &e.salary) == 4) {
        if (e.id == targetID) {
            printf("Record Found: %s - %s\n", e.name, e.designation);
            found = 1;
            break;
        }
    }
    if (!found) printf("Employee with ID %d not found.\n", targetID);
    fclose(fp);
}
