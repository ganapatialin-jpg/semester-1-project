// DELETE Operation using Temp-File Swap 
void deleteEmployee() {
    FILE *fp = fopen("employee.txt", "r");
    FILE *ft = fopen("temp.txt", "w");
    Employee e;
    int targetID, found = 0;

    printf("Enter ID to delete: ");
    scanf("%d", &targetID);

    while (fscanf(fp, "%d %s %s %f", &e.id, e.name, e.designation, &e.salary) == 4) {
        if (e.id == targetID) {
            found = 1;
        } else {
            fprintf(ft, "%d %s %s %.2f\n", e.id, e.name, e.designation, e.salary);
        }
    }

    fclose(fp);
    fclose(ft);

    remove("employee.txt");
    rename("temp.txt", "employee.txt"); // Swapping temp to original 

    if (found) printf("Record deleted.\n");
    else printf("Record not found.\n");
}
